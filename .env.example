# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth provider: "mock" for local prototype, "clerk" or "supabase" for production.
AUTH_PROVIDER=mock

# Clerk, if selected
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase, if selected
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database, if using Prisma/Postgres directly
DATABASE_URL=

# Optional allowlist for first production rollout
ALLOWED_EMAIL_DOMAINS=
ALLOWED_USER_EMAILS=
