{
  "name": "part-time-scheduler",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w apps/web",
    "typecheck": "npm run typecheck -w packages/scheduler-core && npm run typecheck -w apps/web",
    "lint": "npm run lint -w apps/web"
  },
  "dependencies": {
    "@part-time/scheduler-core": "file:packages/scheduler-core"
  }
}
